NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Upload limits
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=8
MAX_FILES_PER_REQUEST=20

# OCR.space API  (free at https://ocr.space/ocrapi — 25,000 req/month)
OCR_SPACE_API_KEY=your_ocr_space_api_key_here
OCR_USE_GEMINI_VISION=true
OCR_FALLBACK_TO_OCR_SPACE=false
OCR_MAX_IMAGE_WIDTH=1800
OCR_JPEG_QUALITY=82
OCR_REQUEST_TIMEOUT_MS=90000
OCR_MAX_RETRIES=2
OCR_RETRY_DELAY_MS=1500
OCR_ENGINE=2
OCR_FALLBACK_ENGINE=1

# Gemini API  (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-2.5-flash

# Daily limit
DAILY_CARD_LIMIT=200
DAILY_LIMIT_TIMEZONE=Asia/Kolkata

# Google Sheets (auto-save results)
SHEETS_ENABLED=true
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
